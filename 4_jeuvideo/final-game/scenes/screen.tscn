[sub_resource type="GDScript" id="GDScript_gapb5"]
script/source = "extends Control

@onready var search_field = $LineEdit
@onready var result_label = $Label
@onready var http = $HTTPRequest

func _ready() -> void:
	search_field.text = \"Search\"

func _on_button_pressed():
	$Label.show()
	var query = search_field.text
	if query == \"\":
		return
	
	result_label.text = \"Recherche en cours...\"
	
	var url = \"https://api.duckduckgo.com/?q=\" + query.uri_encode() + \"&format=json&no_html=1\"
	http.request(url)

func _on_http_request_completed(result, response_code, headers, body):
	var json = JSON.parse_string(body.get_string_from_utf8())
	
	if json == null:
		result_label.text = \"Erreur de parsing\"
		return
	
	var text = json.get(\"AbstractText\", \"\")
	
	if text == \"\":
		result_label.text = \"Aucun résultat trouvé.\"
		$Timer.start()
		
	else:
		result_label.text = text

func _on_quit_pressed() -> void:
	$Label.hide()

func _on_timer_timeout() -> void:
	$Label.hide()
	$Timer.wait_time = 0
	$Timer.stop()


# Aide de claude
# Je voulais voir si c'était possible de faire une recherche directement surr
# internet et donc j'ai dmd à CLaude qui m'a dit oui

# Réponse
#Oui ! Voici comment faire une recherche simple avec un LineEdit et un Label :
#Setup de la scène
#Control
#├── LineEdit      (la barre de recherche)
#├── Button        (bouton rechercher)
#└── Label         (affiche les résultats)
#
#Le script
#gdscriptextends Control
#
#@onready var search_field = $LineEdit
#@onready var result_label = $Label
#@onready var http = $HTTPRequest
#
#func _on_button_pressed():
	#var query = search_field.text
	#if query == \"\":
		#return
	#
	#result_label.text = \"Recherche en cours...\"
	#
	#var url = \"https://api.duckduckgo.com/?q=\" + query.uri_encode() + \"&format=json&no_html=1\"
	#http.request(url)
#
#func _on_http_request_completed(result, response_code, headers, body):
	#var json = JSON.parse_string(body.get_string_from_utf8())
	#
	#if json == null:
		#result_label.text = \"Erreur de parsing\"
		#return
	#
	#var text = json.get(\"AbstractText\", \"\")
	#
	#if text == \"\":
		#result_label.text = \"Aucun résultat trouvé.\"
	#else:
		#result_label.text = text
#
#N'oublie pas dans l'inspecteur
#
#Ajouter un noeud HTTPRequest à la scène
#Connecter le signal request_completed du HTTPRequest à _on_http_request_completed
#Connecter le signal pressed du Button à _on_button_pressed
#Activer autowrap_mode sur le Label pour que le texte revienne à la ligne
#
"

